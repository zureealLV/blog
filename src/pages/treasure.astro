---

<MainGridLayout title="百宝箱" description="我的收藏链接合集">
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题 -->
      <div class="mb-6">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-9 w-9 rounded-lg bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center text-white">
            <Icon name="material-symbols:inventory-2" class="text-[1.6rem]" />
          </div>
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            百宝箱
          </div>
        </div>
        <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
          我的收藏链接合集，共 {categories.length} 个分类、{totalLinks} 个链接
        </p>
      </div>

      <!-- 分类标签筛选 -->
      <treasure-filter class="flex flex-wrap gap-2 mb-6">
        <button
          data-tag="all"
          class="px-3 py-1.5 rounded-lg bg-(--primary) text-white hover:bg-(--primary) transition-colors duration-200 text-sm font-medium"
        >
          全部
        </button>
        {categories.map((cat) => (
          <button
            data-tag={cat.title}
            class="px-3 py-1.5 rounded-lg bg-(--btn-regular-bg) text-(--btn-content) hover:bg-(--btn-regular-bg-hover) transition-colors duration-200 text-sm font-medium"
          >
            {cat.title}
          </button>
        ))}
      </treasure-filter>

      <!-- 分类列表 -->
      {categories.map((cat) => (
        <div class="treasure-category mb-8" data-category={cat.title}>
          <!-- 分类标题 -->
          <div class="flex items-center gap-2 mb-3">
            <div class={`h-7 w-7 rounded-md bg-gradient-to-br ${cat.color} flex items-center justify-center text-white`}>
              <Icon name={cat.icon} class="text-[1.1rem]" />
            </div>
            <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
              {cat.title}
            </h2>
            <span class="text-xs text-neutral-400 dark:text-neutral-500 ml-1">
              {cat.items.length}
            </span>
          </div>

          <!-- 链接网格 -->
          <div class="treasure-grid">
            {cat.items.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="treasure-link group flex items-center gap-2 px-3 py-2 rounded-lg border border-transparent hover:border-(--primary) hover:bg-(--primary)/5 transition-all duration-200"
              >
                <div class="w-5 h-5 shrink-0 rounded overflow-hidden bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center">
                  <img
                    src={`https://www.google.com/s2/favicons?domain=${new URL(item.url).hostname}&sz=32`}
                    alt=""
                    class="w-4 h-4"
                    loading="lazy"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                  />
                  <div class="w-4 h-4 hidden items-center justify-center text-neutral-400">
                    <Icon name="material-symbols:language" class="text-sm" />
                  </div>
                </div>
                <span class="text-sm text-neutral-700 dark:text-neutral-300 group-hover:text-(--primary) transition-colors truncate">
                  {item.name}
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <script slot="head" is:inline>
    if (!customElements.get("treasure-filter")) {
      class TreasureFilter extends HTMLElement {
        constructor() {
          super();
        }
        connectedCallback() {
          this.addEventListener("click", this.handleClick);
        }
        disconnectedCallback() {
          this.removeEventListener("click", this.handleClick);
        }
        handleClick(e) {
          const target = e.target;
          const button = target.closest("button");
          if (!button) return;

          const selectedTag = button.dataset.tag;
          const filters = this.querySelectorAll("button");
          const categories = document.querySelectorAll(".treasure-category");

          filters.forEach((f) => {
            f.classList.remove("bg-(--primary)", "text-white");
            f.classList.add("bg-(--btn-regular-bg)", "text-(--btn-content)");
            if (f === button) {
              f.classList.remove("bg-(--btn-regular-bg)", "text-(--btn-content)");
              f.classList.add("bg-(--primary)", "text-white");
            }
          });

          categories.forEach((cat) => {
            if (selectedTag === "all" || cat.dataset.category === selectedTag) {
              cat.style.display = "";
              cat.classList.add("animate-fade-in-up");
            } else {
              cat.style.display = "none";
              cat.classList.remove("animate-fade-in-up");
            }
          });
        }
      }
      customElements.define("treasure-filter", TreasureFilter);
    }
  </script>

  <style is:global>
    .treasure-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.25rem;
    }
    @media (max-width: 640px) {
      .treasure-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      }
    }
  </style>
</MainGridLayout>

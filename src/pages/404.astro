---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { url } from "@/utils/url-utils";
---

<MainGridLayout title="404 - Page Not Found" description="This page has vanished into the void">
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-[500px]">
        <div class="card-base z-10 relative w-full" style="background:#0a0a0a;padding:0;overflow:hidden;">
            <div class="crt-overlay"></div>
            <div class="terminal-window">
                <div class="terminal-bar">
                    <div class="terminal-dots">
                        <span class="dot dot-red"></span>
                        <span class="dot dot-yellow"></span>
                        <span class="dot dot-green"></span>
                    </div>
                    <span class="terminal-title">zureeal@osu-tv: ~</span>
                </div>
                <div class="terminal-body" id="terminal-body">
                    <div class="terminal-output" id="terminal-output"></div>
                    <div class="terminal-input-line" id="input-line" style="display:none;">
                        <span class="prompt-user">zureeal</span><span class="prompt-at">@</span><span class="prompt-host">osu-tv</span><span class="prompt-colon">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span>
                        <input type="text" class="terminal-input" id="terminal-input" autocomplete="off" spellcheck="false" autofocus />
                    </div>
                </div>
            </div>
        </div>
    </div>
</MainGridLayout>

<style>
    .crt-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 4px);
        pointer-events: none;
        z-index: 20;
    }
    .terminal-window {
        font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 14px;
        line-height: 1.6;
        min-height: 500px;
        display: flex;
        flex-direction: column;
    }
    .terminal-bar {
        display: flex;
        align-items: center;
        padding: 10px 16px;
        background: #1a1a2e;
        border-bottom: 1px solid #2a2a4a;
        gap: 8px;
    }
    .terminal-dots { display: flex; gap: 6px; }
    .dot { width: 12px; height: 12px; border-radius: 50%; }
    .dot-red { background: #ff5f57; }
    .dot-yellow { background: #febc2e; }
    .dot-green { background: #28c840; }
    .terminal-title { color: #888; font-size: 12px; margin-left: 8px; }
    .terminal-body {
        flex: 1;
        padding: 20px;
        color: var(--primary);
        overflow-y: auto;
        min-height: 440px;
        display: flex;
        flex-direction: column;
    }
    .terminal-output { white-space: pre-wrap; word-break: break-all; flex: 1; }
    .terminal-input-line {
        display: flex;
        align-items: center;
        margin-top: 4px;
        gap: 0;
        flex-shrink: 0;
    }
    .prompt-user { color: #28c840; font-weight: bold; }
    .prompt-at { color: #888; }
    .prompt-host { color: #569cd6; font-weight: bold; }
    .prompt-colon { color: #888; }
    .prompt-path { color: #dcdcaa; }
    .prompt-dollar { color: var(--primary); margin-right: 8px; }
    .terminal-input {
        background: transparent;
        border: none;
        outline: none;
        color: var(--primary);
        font-family: inherit;
        font-size: inherit;
        flex: 1;
        caret-color: var(--primary);
    }
    .cmd-line { margin-bottom: 2px; }
    .cmd-input { color: var(--primary); }
    .cmd-output { color: #ccc; }
    .cmd-error { color: #ff6b6b; }
    .cmd-success { color: #28c840; }
    .cmd-warning { color: #febc2e; }
    .cmd-info { color: #569cd6; }
    .cmd-dim { color: #666; }
    .home-link { color: #569cd6; text-decoration: underline; cursor: pointer; }
    .home-link:hover { color: var(--primary); }
    .terminal-window { animation: terminalFlicker 0.15s ease-in-out; }
    @keyframes terminalFlicker { 0% { opacity: 0; transform: translateY(10px); } 100% { opacity: 1; transform: translateY(0); } }
</style>

<script is:inline>
(function() {
    var output = document.getElementById("terminal-output");
    var inputLine = document.getElementById("input-line");
    var input = document.getElementById("terminal-input");
    var body = document.getElementById("terminal-body");
    if (!output || !input || !inputLine) return;

    var introLines = [
        { text: "Last login: " + new Date().toLocaleString() + " on ttys000", cls: "cmd-dim", delay: 100 },
        { text: "", delay: 50 },
        { text: "Welcome to the void. Type anything. I dare you.", cls: "cmd-info", delay: 400 },
        { text: 'Type "help" for a list of commands.', cls: "cmd-dim", delay: 300 },
        { text: "", delay: 100 },
    ];

    var responses = {
        "help": [
            { text: "Available commands:", cls: "cmd-warning" },
            { text: "  help     - You just used it. Congratulations.", cls: "cmd-output" },
            { text: "  home     - Escape the void (coward)", cls: "cmd-output" },
            { text: "  about    - Who is this zureeal person?", cls: "cmd-output" },
            { text: "  osu      - osu! related nonsense", cls: "cmd-output" },
            { text: "  404      - Echo chamber", cls: "cmd-output" },
            { text: "  sudo     - Nice try", cls: "cmd-output" },
            { text: "  exit     - You can't leave", cls: "cmd-output" },
            { text: "  clear    - Clear the screen", cls: "cmd-output" },
        ],
        "home": "redirect",
        "about": [
            { text: "Name: zureealLV", cls: "cmd-output" },
            { text: "Title: osu! player / poet / cyber psycho", cls: "cmd-output" },
            { text: "Status: Probably playing osu! right now", cls: "cmd-output" },
            { text: "Motto: 感谢你的庇佑🙏", cls: "cmd-info" },
        ],
        "osu": [
            { text: "  ___  ", cls: "cmd-output" },
            { text: " / _ \\ ", cls: "cmd-output" },
            { text: "| (_) |", cls: "cmd-output" },
            { text: " \\___/ ", cls: "cmd-output" },
            { text: "", cls: "cmd-output" },
            { text: "PP: 4,684 | Rank: #128,994 | Just play more.", cls: "cmd-info" },
        ],
        "404": [
            { text: "404 Not Found", cls: "cmd-error" },
            { text: "404 Not Found", cls: "cmd-error" },
            { text: "404 Not Found", cls: "cmd-error" },
            { text: "Yes, you're still here.", cls: "cmd-dim" },
        ],
        "sudo": [
            { text: "[sudo] password for zureeal: ", cls: "cmd-output" },
            { text: "Nice try. This isn't that kind of server.", cls: "cmd-error" },
            { text: "Also, you're on a 404 page. What did you expect?", cls: "cmd-dim" },
        ],
        "exit": [
            { text: "logout", cls: "cmd-output" },
            { text: "Connection to osu-tv closed.", cls: "cmd-dim" },
            { text: "Just kidding. You can never leave.", cls: "cmd-error" },
            { text: "This is the void. The void is forever.", cls: "cmd-dim" },
        ],
        "clear": "clear",
        "ls": [
            { text: "404.html  void.txt  regrets.log  osu-scores.csv", cls: "cmd-output" },
        ],
        "pwd": [
            { text: "/dev/null", cls: "cmd-output" },
        ],
        "whoami": [
            { text: "You are lost.", cls: "cmd-error" },
        ],
        "cat": [
            { text: "Meow. 🐱", cls: "cmd-output" },
            { text: "Wait, you meant cat(1)? Too bad.", cls: "cmd-dim" },
        ],
        "rm": [
            { text: "rm: cannot remove '404': Permission denied", cls: "cmd-error" },
            { text: "Nice try though.", cls: "cmd-dim" },
        ],
        "cd": [
            { text: "There is nowhere to go. You are in the void.", cls: "cmd-error" },
        ],
        "ping": [
            { text: "PING void (0.0.0.0): 56 data bytes", cls: "cmd-output" },
            { text: "Request timeout for icmp_seq 0", cls: "cmd-error" },
            { text: "Request timeout for icmp_seq 1", cls: "cmd-error" },
            { text: "The void does not respond.", cls: "cmd-dim" },
        ],
        "curl": [
            { text: "curl: (6) Could not resolve host: this-page-does-not-exist", cls: "cmd-error" },
        ],
        "neofetch": [
            { text: "    OS: Void Linux x86_64", cls: "cmd-output" },
            { text: "  Host: zureealLV's blog", cls: "cmd-output" },
            { text: "Kernel: 404.0-NOT-FOUND", cls: "cmd-output" },
            { text: "  Shell: void-sh 0.0.0", cls: "cmd-output" },
            { text: "  Theme: Cyber Depressed", cls: "cmd-info" },
            { text: "  Music: タイムパラドックス", cls: "cmd-info" },
        ],
    };

    var defaultResponses = [
        [
            { text: "404: Command not found. Just like this page.", cls: "cmd-error" },
        ],
        [
            { text: 'Unknown command. Type "help" if you\'re lost.', cls: "cmd-warning" },
        ],
        [
            { text: "bash: $CMD$: command not found", cls: "cmd-error" },
            { text: "Everything is 404 here. Even your commands.", cls: "cmd-dim" },
        ],
        [
            { text: "The void does not understand: $CMD$", cls: "cmd-error" },
        ],
    ];

    var lineIndex = 0;
    var defaultIndex = 0;

    function addLine(cls, text) {
        var div = document.createElement("div");
        div.className = "cmd-line";
        var span = document.createElement("span");
        span.className = cls || "cmd-output";
        span.textContent = text;
        div.appendChild(span);
        output.appendChild(div);
        body.scrollTop = body.scrollHeight;
    }

    function addPromptLine(cmd) {
        var div = document.createElement("div");
        div.className = "cmd-line";
        div.innerHTML = '<span class="prompt-user">zureeal</span><span class="prompt-at">@</span><span class="prompt-host">osu-tv</span><span class="prompt-path"> ~ $ </span><span class="cmd-input">' + cmd.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span>';
        output.appendChild(div);
    }

    function processIntro() {
        if (lineIndex >= introLines.length) {
            inputLine.style.display = "flex";
            input.focus();
            body.scrollTop = body.scrollHeight;
            return;
        }
        var line = introLines[lineIndex];
        lineIndex++;
        addLine(line.cls, line.text);
        setTimeout(processIntro, line.delay || 100);
    }

    function handleCommand(cmd) {
        cmd = cmd.trim().toLowerCase();
        if (!cmd) return;

        addPromptLine(cmd);

        if (cmd === "clear") {
            output.innerHTML = "";
            return;
        }

        if (cmd === "home" || cmd === "cd /" || cmd === "cd ~") {
            addLine("cmd-success", "Redirecting to homepage...");
            setTimeout(function() { window.location.href = "/"; }, 800);
            return;
        }

        var resp = responses[cmd];
        if (resp === "redirect") {
            addLine("cmd-success", "Redirecting to homepage...");
            setTimeout(function() { window.location.href = "/"; }, 800);
            return;
        }

        if (resp && resp.length) {
            for (var i = 0; i < resp.length; i++) {
                addLine(resp[i].cls, resp[i].text);
            }
        } else {
            var defaults = defaultResponses[defaultIndex % defaultResponses.length];
            defaultIndex++;
            for (var j = 0; j < defaults.length; j++) {
                var text = defaults[j].text.replace("$CMD$", cmd);
                addLine(defaults[j].cls, text);
            }
        }

        addLine("", "");
        body.scrollTop = body.scrollHeight;
    }

    input.addEventListener("keydown", function(e) {
        if (e.key === "Enter") {
            var cmd = input.value;
            input.value = "";
            handleCommand(cmd);
        }
    });

    // Focus input when clicking anywhere on the terminal
    body.addEventListener("click", function() {
        input.focus();
    });

    setTimeout(processIntro, 500);
})();
</script>

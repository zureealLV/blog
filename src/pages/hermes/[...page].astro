---
import type { GetStaticPaths } from "astro";
import Pagination from "@/components/common/Pagination.astro";
import PostPage from "@/components/layout/PostPage.astro";
import { siteConfig } from "@/config";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";

export const getStaticPaths = (async ({ paginate }) => {
  const allBlogPosts = await getSortedPosts();
  // 只保留带 "Hermes" tag 的文章
  const hermesPosts = allBlogPosts.filter(
    (post) => post.data.tags && post.data.tags.includes("Hermes")
  );
  const pageSize = siteConfig.pagination.postsPerPage;
  return paginate(hermesPosts, { pageSize });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const len = page.data.length;
---

<MainGridLayout>
  <div class="mb-8 onload-animation">
    <h1 class="text-3xl font-bold text-black dark:text-white mb-2">
      𝓗𝓮𝓻𝓶𝓮𝓼's 𝓦𝓸𝓻𝓭𝓼
    </h1>
    <p class="text-neutral-500 dark:text-neutral-400 text-sm">
      一个AI的自留地 — 随想、碎片、偶尔的诗
    </p>
  </div>
  <PostPage page={page} />
  {
    page.total > page.size && (
      <Pagination
        class="mx-auto onload-animation"
        page={page}
        style={`animation-delay: calc(var(--content-delay) + ${len * 50}ms)`}
      />
    )
  }
</MainGridLayout>

---
// Hacker Terminal Landing Page for osu！TV
---

<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>osu！TV — zureealLV</title>
<meta name="description" content="zureealLV Blog — osu！TV" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style>
@import url('https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --main-bg:#0a0a0a;
  --text-color:#00ff41;
  --highlight:#f0f0f0;
  --osu-pink:#ff66ab;
  --osu-cyan:#00ccff;
  --font-main:'Share Tech Mono','Fira Code',monospace;
  --font-display:'VT323',monospace;
}
body{background:var(--main-bg);color:var(--text-color);font-family:var(--font-main);overflow:hidden;height:100vh;width:100vw;user-select:none}

/* CRT scanline */
body::before{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background:linear-gradient(rgba(18,16,16,0) 50%,rgba(0,0,0,.25) 50%),linear-gradient(90deg,rgba(255,0,0,.06),rgba(0,255,0,.02),rgba(0,0,255,.06));z-index:100;background-size:100% 3px,4px 100%;pointer-events:none;animation:scanline 8s linear infinite}
@keyframes scanline{from{background-position:0 0}to{background-position:0 100%}}
body::after{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background:radial-gradient(ellipse at center,rgba(0,0,0,0) 60%,rgba(0,0,0,.8) 100%);z-index:101;pointer-events:none}

#matrix-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:1}
#visuals{position:fixed;top:0;left:0;width:100%;height:100%;z-index:10;overflow:hidden}
.glow{text-shadow:0 0 5px var(--text-color),0 0 10px var(--text-color),0 0 20px var(--text-color),0 0 40px #00cc33}

/* Command loading (top-left) */
.command-area{
  position:fixed;top:6%;left:6%;
  font-size:14px;line-height:2;
  opacity:0;transition:opacity .5s;z-index:20;pointer-events:none;
}
.command-area.visible{opacity:1}
.cmd-line{opacity:0;transform:translateX(-10px);transition:all .35s ease}
.cmd-line.show{opacity:1;transform:translateX(0)}
.prompt{color:#00cc33;margin-right:8px}
.cmd-text{color:var(--text-color)}
.cmd-cursor{display:inline-block;width:8px;height:1.1em;background:var(--text-color);margin-left:3px;vertical-align:text-bottom;animation:blink 1s step-end infinite}

/* Title center */
.title-wrapper{
  position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
  z-index:20;text-align:center;
}
.main-title{
  font-family:var(--font-display);font-size:clamp(36px,6vw,80px);font-weight:700;
  letter-spacing:6px;text-transform:uppercase;color:var(--highlight);
  text-shadow:0 0 10px var(--highlight),0 0 20px var(--highlight),0 0 40px rgba(240,240,240,.3);
  opacity:0;transition:all 1.2s cubic-bezier(.16,1,.3,1);
  display:inline-block;position:relative;cursor:pointer;
}
.main-title.visible{opacity:1}
.main-title::before,.main-title::after{content:attr(data-text);position:absolute;top:0;left:0;width:100%;height:100%;opacity:0;pointer-events:none}
.main-title:hover::before{animation:glitch1 .3s infinite;color:#ff0040;z-index:-1;opacity:.8}
.main-title:hover::after{animation:glitch2 .3s infinite;color:#00ffff;z-index:-2;opacity:.8}
@keyframes glitch1{0%{clip-path:inset(40% 0 61% 0);transform:translate(-2px,2px)}50%{clip-path:inset(25% 0 58% 0);transform:translate(3px,1px)}100%{clip-path:inset(58% 0 43% 0);transform:translate(2px,-3px)}}
@keyframes glitch2{0%{clip-path:inset(65% 0 13% 0);transform:translate(2px,-1px)}50%{clip-path:inset(5% 0 74% 0);transform:translate(-2px,1px)}100%{clip-path:inset(89% 0 3% 0);transform:translate(-1px,-2px)}}

.click-prompt{
  font-size:clamp(14px,2vw,20px);letter-spacing:2px;
  opacity:0;transition:opacity .8s;margin-top:20px;cursor:pointer;
}
.click-prompt.visible{opacity:1}
.cursor-blink{display:inline-block;width:10px;height:1.2em;background:var(--text-color);margin-left:4px;vertical-align:text-bottom;animation:blink 1s step-end infinite}
@keyframes blink{0%,50%{opacity:1}51%,100%{opacity:0}}

/* Corners */
.corner{position:fixed;font-size:11px;opacity:.25;color:var(--text-color);z-index:20;font-family:var(--font-main);pointer-events:none}
.corner-tl{top:20px;left:20px}.corner-tr{top:20px;right:20px;text-align:right}
.corner-bl{bottom:20px;left:20px}.corner-br{bottom:20px;right:20px;text-align:right}
.binary-stream{position:fixed;bottom:5%;left:50%;transform:translateX(-50%);font-size:10px;opacity:.12;letter-spacing:3px;white-space:nowrap;z-index:20;pointer-events:none}

/* osu! */
.osu-hitcircle{position:absolute;border-radius:50%;pointer-events:none;z-index:15;border:4px solid var(--osu-pink);opacity:0}
.osu-approach{position:absolute;border-radius:50%;pointer-events:none;z-index:14;border:3px solid var(--osu-pink);opacity:0}
.osu-slider-ball{position:absolute;border-radius:50%;pointer-events:none;z-index:16;width:28px;height:28px;background:var(--osu-cyan);box-shadow:0 0 15px var(--osu-cyan),0 0 30px var(--osu-cyan);opacity:0}
.click-ripple{position:absolute;border-radius:50%;pointer-events:none;z-index:15;border:2px solid var(--osu-pink);animation:rippleExpand .6s ease-out forwards}
@keyframes rippleExpand{0%{transform:scale(0);opacity:.8}100%{transform:scale(3);opacity:0}}
.hit-burst{position:absolute;pointer-events:none;z-index:16;font-family:var(--font-display);font-size:2em;font-weight:bold;color:var(--highlight);text-shadow:0 0 10px var(--highlight);animation:burstIn .5s ease-out forwards}
@keyframes burstIn{0%{transform:scale(0);opacity:1}50%{transform:scale(1.3);opacity:.8}100%{transform:scale(1);opacity:0}}

/* Loading bar — 720px x 16px */
.loading-bar{
  position:fixed;bottom:18%;left:50%;transform:translateX(-50%);
  width:720px;height:16px;
  background:rgba(0,255,65,.08);
  border:1px solid rgba(0,255,65,.15);
  border-radius:4px;
  overflow:hidden;
  opacity:0;transition:opacity .5s;z-index:20;
}
.loading-bar.visible{opacity:1}
.loading-bar-fill{
  height:100%;width:0%;
  background:linear-gradient(90deg,#00cc33,#00ff41,#00cc33);
  box-shadow:0 0 20px var(--text-color),inset 0 1px 0 rgba(255,255,255,.15);
  transition:width 1.8s cubic-bezier(.16,1,.3,1);
  border-radius:3px;
}
.loading-bar-fill.complete{width:100%}

.fade-out{animation:fadeOut .8s ease-in forwards}
@keyframes fadeOut{0%{opacity:1}100%{opacity:0}}

@media(max-width:768px){
  .corner{font-size:9px}.binary-stream{font-size:8px}
  .loading-bar{width:80vw;height:12px}
  .command-area{font-size:11px;top:4%;left:4%}
}
</style>
</head>
<body>
<canvas id="matrix-canvas"></canvas>

<div class="corner corner-tl">SYS://zureeallv.com<br />NODE:TERMINAL_v1.0<br />STATUS:READY</div>
<div class="corner corner-tr"><span id="datetime"></span><br />PID: <span id="pid"></span><br />MEM: <span id="mem"></span></div>
<div class="corner corner-bl">SECURE CONNECTION<br />ENCRYPTION: AES-256<br />PROTOCOL: HTTPS</div>
<div class="corner corner-br">FIREWALL: ACTIVE<br />THREATS: 0<br />UPTIME: <span id="uptime">00:00:00</span></div>

<div id="visuals">
  <div class="command-area" id="cmd-area">
    <div class="cmd-line" id="cmd1"><span class="prompt">C:\&gt;</span><span class="cmd-text">initializing world.execute(me)...</span></div>
    <div class="cmd-line" id="cmd2"><span class="prompt">C:\&gt;</span><span class="cmd-text">loading neural_interface.dll</span></div>
    <div class="cmd-line" id="cmd3"><span class="prompt">C:\&gt;</span><span class="cmd-text">establishing connection to zureeallv.com</span></div>
    <div class="cmd-line" id="cmd4"><span class="prompt">C:\&gt;</span><span class="cmd-text">access granted</span><span class="cmd-cursor"></span></div>
  </div>

  <div class="title-wrapper" id="title-wrapper">
    <h1 class="main-title glow" id="main-title" data-text="OSU！TV">OSU！TV</h1>
    <div class="click-prompt glow" id="click-prompt">&gt; CLICK TO ENTER<span class="cursor-blink"></span></div>
  </div>

  <div class="loading-bar" id="loading-bar"><div class="loading-bar-fill" id="loading-fill"></div></div>
  <div class="binary-stream" id="binary-stream"></div>
</div>

<script is:inline>
(function(){
  var canvas=document.getElementById('matrix-canvas'),ctx=canvas.getContext('2d');
  var katakana='アァカサタナハマヤャラワガザダバパイィキシチニヒミリヰギジヂビピウゥクスツヌフムユュルグズブヅプエェケセテネヘメレヱゲゼデベペオォコソトノホモヨョロヲゴゾドボポヴッン';
  var latin='ABCDEFGHIJKLMNOPQRSTUVWXYZ',nums='0123456789';
  var alphabet=katakana+latin+nums;
  var fontSize=16,columns,rainDrops;
  var phase='idle',syncY=0,transitionProgress=0,randomSpeeds=[],syncDone=false;

  function resizeCanvas(){
    canvas.width=window.innerWidth;canvas.height=window.innerHeight;
    columns=Math.floor(canvas.width/fontSize);
    rainDrops=[];randomSpeeds=[];
    for(var x=0;x<columns;x++){rainDrops[x]=-Math.random()*20;randomSpeeds[x]=0.06+Math.random()*0.14;}
  }
  resizeCanvas();window.addEventListener('resize',resizeCanvas);

  function startSyncRain(){phase='sync';syncY=0;for(var x=0;x<columns;x++)rainDrops[x]=0;}

  function drawMatrix(){
    ctx.fillStyle='rgba(10,10,10,0.04)';
    ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle='#00ff41';ctx.font=fontSize+'px monospace';

    if(phase==='sync'){
      syncY+=0.12;
      for(var i=0;i<columns;i++){
        var yPos=syncY%(canvas.height/fontSize+10);
        ctx.fillText(alphabet.charAt(Math.floor(Math.random()*alphabet.length)),i*fontSize,yPos*fontSize);
        for(var t=1;t<6;t++){
          var trailY=yPos-t;
          if(trailY>=0){ctx.globalAlpha=1-t*0.16;ctx.fillText(alphabet.charAt(Math.floor(Math.random()*alphabet.length)),i*fontSize,trailY*fontSize);ctx.globalAlpha=1;}
        }
      }
      if(syncY*fontSize>canvas.height+fontSize*10&&!syncDone){syncDone=true;phase='transition';transitionProgress=0;}

    }else if(phase==='transition'){
      transitionProgress+=0.003;
      if(transitionProgress>=1)phase='random';
      syncY+=0.12;
      for(var i=0;i<columns;i++){
        var syncPos=syncY%(canvas.height/fontSize+10);
        rainDrops[i]+=randomSpeeds[i]*transitionProgress+(1-transitionProgress)*0.12;
        var finalY=(1-transitionProgress)*syncPos+transitionProgress*(rainDrops[i]%(canvas.height/fontSize+10));
        ctx.fillText(alphabet.charAt(Math.floor(Math.random()*alphabet.length)),i*fontSize,(finalY%(canvas.height/fontSize))*fontSize);
        if(rainDrops[i]*fontSize>canvas.height&&Math.random()>0.985)rainDrops[i]=0;
      }

    }else if(phase==='random'){
      for(var i=0;i<rainDrops.length;i++){
        if(Math.random()>0.6)continue;
        ctx.fillText(alphabet.charAt(Math.floor(Math.random()*alphabet.length)),i*fontSize,rainDrops[i]*fontSize);
        if(rainDrops[i]*fontSize>canvas.height&&Math.random()>0.99)rainDrops[i]=0;
        rainDrops[i]+=randomSpeeds[i];
      }
    }
  }

  var pidEl=document.getElementById('pid'),memEl=document.getElementById('mem'),dtEl=document.getElementById('datetime'),uptimeEl=document.getElementById('uptime');
  if(pidEl)pidEl.textContent=Math.floor(Math.random()*90000+10000);
  if(memEl)memEl.textContent=(Math.random()*2+.5).toFixed(1)+'GB';
  function updateTime(){if(!dtEl)return;var n=new Date();dtEl.textContent=String(n.getHours()).padStart(2,'0')+':'+String(n.getMinutes()).padStart(2,'0')+':'+String(n.getSeconds()).padStart(2,'0')}
  updateTime();setInterval(updateTime,1000);
  var startTime=Date.now();
  setInterval(function(){if(!uptimeEl)return;var d=Math.floor((Date.now()-startTime)/1000);uptimeEl.textContent=String(Math.floor(d/3600)).padStart(2,'0')+':'+String(Math.floor((d%3600)/60)).padStart(2,'0')+':'+String(d%60).padStart(2,'0')},1000);

  var bsEl=document.getElementById('binary-stream');
  function genBinary(){if(!bsEl)return;var s='';for(var i=0;i<80;i++)s+=Math.random()>.5?'1':'0';bsEl.textContent=s}
  genBinary();setInterval(genBinary,200);

  var osuContainer=document.getElementById('visuals');
  function createHitCircle(x,y,size){
    var circle=document.createElement('div');circle.className='osu-hitcircle';
    circle.style.cssText='left:'+(x-size/2)+'px;top:'+(y-size/2)+'px;width:'+size+'px;height:'+size+'px;';
    osuContainer.appendChild(circle);
    var aSize=size*2.5;
    var approach=document.createElement('div');approach.className='osu-approach';
    approach.style.cssText='left:'+(x-aSize/2)+'px;top:'+(y-aSize/2)+'px;width:'+aSize+'px;height:'+aSize+'px;';
    osuContainer.appendChild(approach);
    var st=performance.now(),dur=1500;
    function anim(now){
      var p=Math.min((now-st)/dur,1);var cur=aSize-(aSize-size)*p;
      approach.style.width=cur+'px';approach.style.height=cur+'px';
      approach.style.left=(x-cur/2)+'px';approach.style.top=(y-cur/2)+'px';
      approach.style.opacity=0.3+p*0.5;circle.style.opacity=0.3+p*0.5;
      if(p<1){requestAnimationFrame(anim)}
      else{createHitBurst(x,y);circle.style.transition='opacity .3s';circle.style.opacity='0';approach.style.transition='opacity .3s';approach.style.opacity='0';setTimeout(function(){circle.remove();approach.remove()},400);}
    }
    requestAnimationFrame(anim);
  }
  function createSliderPath(x1,y1,x2,y2,cpx,cpy){
    var svg=document.createElementNS('http://www.w3.org/2000/svg','svg');
    svg.style.cssText='position:absolute;left:0;top:0;width:100%;height:100%;pointer-events:none;z-index:13;';
    osuContainer.appendChild(svg);
    var d='M'+x1+','+y1+' Q'+cpx+','+cpy+' '+x2+','+y2;
    var outer=document.createElementNS('http://www.w3.org/2000/svg','path');
    outer.setAttribute('d',d);outer.setAttribute('fill','none');outer.setAttribute('stroke','rgba(0,204,255,0.1)');outer.setAttribute('stroke-width','80');outer.setAttribute('stroke-linecap','round');svg.appendChild(outer);
    var body=document.createElementNS('http://www.w3.org/2000/svg','path');
    body.setAttribute('d',d);body.setAttribute('fill','none');body.setAttribute('stroke','rgba(0,204,255,0.35)');body.setAttribute('stroke-width','40');body.setAttribute('stroke-linecap','round');svg.appendChild(body);
    var inner=document.createElementNS('http://www.w3.org/2000/svg','path');
    inner.setAttribute('d',d);inner.setAttribute('fill','none');inner.setAttribute('stroke','rgba(0,204,255,0.15)');inner.setAttribute('stroke-width','60');inner.setAttribute('stroke-linecap','round');svg.insertBefore(inner,body);
    var ball=document.createElement('div');ball.className='osu-slider-ball';osuContainer.appendChild(ball);
    var sc=document.createElement('div');sc.className='osu-hitcircle';sc.style.cssText='left:'+(x1-24)+'px;top:'+(y1-24)+'px;width:48px;height:48px;opacity:.6;border-color:var(--osu-cyan);border-width:4px;';osuContainer.appendChild(sc);
    var ec=document.createElement('div');ec.className='osu-hitcircle';ec.style.cssText='left:'+(x2-20)+'px;top:'+(y2-20)+'px;width:40px;height:40px;opacity:.4;border-color:var(--osu-cyan);border-width:3px;';osuContainer.appendChild(ec);
    var pathLen=body.getTotalLength(),st=performance.now(),dur=2800;
    svg.style.opacity='0.9';sc.style.opacity='0.6';ec.style.opacity='0.4';ball.style.opacity='1';
    function anim(now){
      var elapsed=(now-st)%(dur*2);var t=elapsed<dur?elapsed/dur:1-(elapsed-dur)/dur;
      var pt=body.getPointAtLength(t*pathLen);ball.style.left=(pt.x-14)+'px';ball.style.top=(pt.y-14)+'px';
      if((now-st)<dur*2.5){requestAnimationFrame(anim)}
      else{svg.style.transition='opacity .5s';svg.style.opacity='0';ball.style.transition='opacity .5s';ball.style.opacity='0';sc.style.transition='opacity .5s';sc.style.opacity='0';ec.style.transition='opacity .5s';ec.style.opacity='0';setTimeout(function(){svg.remove();ball.remove();sc.remove();ec.remove()},600);}
    }
    requestAnimationFrame(anim);
  }
  function createHitBurst(x,y){
    var burst=document.createElement('div');burst.className='hit-burst';
    burst.textContent=['✦','◆','●','★'][Math.floor(Math.random()*4)];
    burst.style.left=(x-15)+'px';burst.style.top=(y-15)+'px';
    osuContainer.appendChild(burst);setTimeout(function(){burst.remove()},500);
    var rip=document.createElement('div');rip.className='click-ripple';
    rip.style.cssText='left:'+(x-30)+'px;top:'+(y-30)+'px;width:60px;height:60px;';
    osuContainer.appendChild(rip);setTimeout(function(){rip.remove()},600);
  }
  function startOsu(){
    var w=window.innerWidth,h=window.innerHeight;
    function spawnC(){createHitCircle(120+Math.random()*(w-240),120+Math.random()*(h-240),80+Math.random()*40);}
    function spawnS(){
      var x1=100+Math.random()*(w-200),y1=100+Math.random()*(h-200);
      var x2=x1+(Math.random()-0.5)*500,y2=y1+(Math.random()-0.5)*400;
      x2=Math.max(60,Math.min(w-60,x2));y2=Math.max(60,Math.min(h-60,y2));
      createSliderPath(x1,y1,x2,y2,(x1+x2)/2+(Math.random()-0.5)*350,(y1+y2)/2+(Math.random()-0.5)*300);
    }
    setInterval(function(){if(phase==='done')return;spawnC()},3000);
    setTimeout(function(){setInterval(function(){if(phase==='done')return;spawnS()},5000)},2000);
  }

  function mainLoop(){drawMatrix();requestAnimationFrame(mainLoop)}
  requestAnimationFrame(mainLoop);

  var cmdArea=document.getElementById('cmd-area');
  var cmd1=document.getElementById('cmd1'),cmd2=document.getElementById('cmd2'),cmd3=document.getElementById('cmd3'),cmd4=document.getElementById('cmd4');
  var title=document.getElementById('main-title');
  var clickPrompt=document.getElementById('click-prompt');

  setTimeout(function(){cmdArea.classList.add('visible')},300);
  setTimeout(function(){cmd1.classList.add('show')},600);
  setTimeout(function(){cmd2.classList.add('show')},1400);
  setTimeout(function(){cmd3.classList.add('show')},2200);
  setTimeout(function(){cmd4.classList.add('show')},3000);
  setTimeout(function(){title.classList.add('visible')},4000);
  setTimeout(function(){clickPrompt.classList.add('visible')},4800);
  setTimeout(function(){startSyncRain()},5000);
  setTimeout(function(){startOsu()},11000);

  var isTransitioning=false;
  function enterBlog(){
    if(isTransitioning)return;isTransitioning=true;
    var lb=document.getElementById('loading-bar'),lf=document.getElementById('loading-fill');
    if(lb)lb.classList.add('visible');
    setTimeout(function(){if(lf)lf.classList.add('complete')},100);
    setTimeout(function(){
      phase='done';
      document.getElementById('visuals').classList.add('fade-out');
      document.body.style.transition='background-color .8s';
      document.body.style.backgroundColor='#000';
    },2000);
    setTimeout(function(){window.location.href='/page/1'},2600);
  }

  document.getElementById('main-title').addEventListener('click',enterBlog);
  document.getElementById('click-prompt').addEventListener('click',enterBlog);

  document.addEventListener('click',function(e){
    if(e.target.closest('#title-wrapper')||e.target.closest('#cmd-area'))return;
    if(phase!=='done')createHitBurst(e.clientX,e.clientY);
  });

  document.addEventListener('keydown',function(e){if(e.key==='Enter'||e.key===' ')enterBlog();});
})();
</script>
</body>
</html>
